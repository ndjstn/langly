# Langly Multi-Agent Platform Configuration
# Copy this file to .env and update values as needed

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=Langly
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=DEBUG

# =============================================================================
# Ollama Settings
# =============================================================================
# URL of the Ollama server
OLLAMA_HOST=http://localhost:11434

# Request timeout for Ollama API calls (seconds)
OLLAMA_TIMEOUT=120

# Pull missing Ollama models on startup
OLLAMA_PREFETCH_MODELS=true

# Warm Ollama models in memory on startup
OLLAMA_PRELOAD_MODELS=true

# Seconds to keep warmed models in memory
OLLAMA_KEEP_ALIVE=300

# =============================================================================
# Neo4j Database Settings
# =============================================================================
# Neo4j connection URI (bolt protocol)
NEO4J_URI=bolt://localhost:7687

# Neo4j authentication credentials
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Neo4j database name
NEO4J_DATABASE=neo4j

# =============================================================================
# Workflow Settings
# =============================================================================
# Maximum number of iterations before workflow timeout
MAX_ITERATIONS=50

# Default operation timeout in seconds
DEFAULT_TIMEOUT=300

# =============================================================================
# V2 Runtime Settings
# =============================================================================
# Enable Neo4j persistence for v2 summaries
ENABLE_NEO4J_MEMORY=false
V2_DB_PATH=./runtime_v2.db

# =============================================================================
# Harness Settings
# =============================================================================
# Auto tools to run on each harness call (comma-separated)
LANGLY_AUTO_TOOLS=greptile,lint,jj,taskwarrior,preflight,mermaid

# Optional MCP browser tool (JSON-RPC endpoint)
LANGLY_MCP_BROWSER_URL=
LANGLY_MCP_BROWSER_AUTO=false
LANGLY_MCP_BROWSER_SCRIPT=
LANGLY_MCP_BROWSER_TIMEOUT_SEC=30

# Optional Playwright / Chrome DevTools MCP endpoints
LANGLY_MCP_PLAYWRIGHT_URL=
LANGLY_MCP_CHROME_URL=

# Taskwarrior MCP server
LANGLY_MCP_TASK_URL=
LANGLY_MCP_TASK_AUTO=false
LANGLY_MCP_TASK_SCRIPT=
LANGLY_MCP_TASK_TIMEOUT_SEC=30

# Vision pipeline for browser outputs
LANGLY_VISION_PIPELINE_CMD=
LANGLY_VISION_TIMEOUT_SEC=30

# Granite vision model (Ollama) for image analysis
LANGLY_VISION_MODEL=granite3.2-vision:latest
LANGLY_VISION_PROMPT=Describe the image, extract any text, and summarize key details.
LANGLY_VISION_MAX_IMAGES=2

# Research + citations (Searx)
LANGLY_RESEARCH_DEFAULT=false
LANGLY_SEARX_URL=http://localhost:8080
LANGLY_SEARX_LIMIT=5
LANGLY_SEARX_TIMEOUT_SEC=6

# Prompt enhancement + citations
LANGLY_PROMPT_ENHANCE_DEFAULT=true
LANGLY_CITATIONS_DEFAULT=false
LANGLY_MODEL_CUTOFF_DATE=2024-06-01

# Tool selection + tuning
LANGLY_TOOL_SELECTION_ENABLED=true
LANGLY_TUNING_DEFAULT=false

# Task capture + templates
LANGLY_TASK_CAPTURE_DEFAULT=false
LANGLY_TASK_CAPTURE_COMMIT=false
LANGLY_TASK_TEMPLATES_DEFAULT=false

# Iteration planning
LANGLY_ITERATION_MAX=3
LANGLY_ITERATION_BUDGET_MS=0
LANGLY_ITERATION_SIMILARITY_STOP=0.96

# Tool retry defaults (0 = no retry)
LANGLY_TOOL_RETRY_DEFAULT=0
LANGLY_TOOL_RETRY_BACKOFF_MS=200
LANGLY_TOOL_RETRY_GREPTILE=2
LANGLY_TOOL_RETRY_LINT=1
LANGLY_TOOL_RETRY_JJ=0
LANGLY_TOOL_RETRY_TASKWARRIOR=0
LANGLY_TOOL_RETRY_BROWSER=0
LANGLY_TOOL_RETRY_PLAYWRIGHT=0
LANGLY_TOOL_RETRY_CHROME_DEVTOOLS=0
LANGLY_TOOL_RETRY_TASK_MCP=0
LANGLY_TOOL_RETRY_PREFLIGHT=0
LANGLY_TOOL_RETRY_MERMAID=0
LANGLY_TOOL_RETRY_VISION=0

# Tool cache
LANGLY_TOOL_CACHE_ENABLED=true
LANGLY_TOOL_CACHE_TTL_SEC=30
LANGLY_TOOL_CACHE_MAX=64
LANGLY_TOOL_CONCURRENCY=4

# Rerun tools after recovery reconfiguration
LANGLY_TOOL_RECOVERY_RERUN=true

# Enable A/B testing by default (false = only when requested)
LANGLY_AB_TEST_DEFAULT=false

# Enable grading by default (false = only when requested)
LANGLY_GRADE_DEFAULT=false

# Streaming batching
LANGLY_STREAM_MIN_CHARS=24
LANGLY_STREAM_FLUSH_MS=120

# Response cache
LANGLY_CACHE_MAX=128
LANGLY_CACHE_TTL_SEC=60

# Greptile MCP server repo path
LANGLY_GREPTILE_DIR=~/Desktop/greptile

# File explorer + uploads
LANGLY_FILE_ROOT=.
LANGLY_UPLOAD_DIR=./uploads

# Zettelkasten notes
LANGLY_ZK_DIR=./zettelkasten

# =============================================================================
# CORS Settings
# =============================================================================
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5001
