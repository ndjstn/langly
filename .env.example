# Langly Multi-Agent Platform Configuration
# Copy this file to .env and update values as needed

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=Langly
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=DEBUG

# =============================================================================
# Ollama Settings
# =============================================================================
# URL of the Ollama server
OLLAMA_HOST=http://localhost:11434

# Request timeout for Ollama API calls (seconds)
OLLAMA_TIMEOUT=120

# =============================================================================
# Neo4j Database Settings
# =============================================================================
# Neo4j connection URI (bolt protocol)
NEO4J_URI=bolt://localhost:7687

# Neo4j authentication credentials
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Neo4j database name
NEO4J_DATABASE=neo4j

# =============================================================================
# Workflow Settings
# =============================================================================
# Maximum number of iterations before workflow timeout
MAX_ITERATIONS=50

# Default operation timeout in seconds
DEFAULT_TIMEOUT=300

# =============================================================================
# CORS Settings
# =============================================================================
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
